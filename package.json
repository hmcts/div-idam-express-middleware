{
  "name": "@hmcts/div-idam-express-middleware",
  "version": "8.0.0",
  "description": "Express middleware for IDAM integration",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "test-coverage": "LOG_LEVEL=OFF nyc --reporter=text mocha services/*.test.js utilities/*.test.js wrapper/*.test.js --recursive",
    "posttest-coverage": "nyc check-coverage --statements 80 --branches 80 --functions 80 --lines 80",
    "test": "yarn lint && yarn test-coverage",
    "test-unit": "NODE_PATH=. mocha services/*.test.js utilities/*.test.js wrapper/*.test.js --reporter spec --recursive -t 3000",
    "sonar-scanner": "node_modules/sonar-scanner/bin/sonar-scanner",
    "audit:check": "chmod +x bin/audit-check.sh && ./bin/audit-check.sh"
  },
  "dependencies": {
    "@hmcts/nodejs-logging": "^4.0.4",
    "diff": "8.0.3",
    "got": "11",
    "jwt-decode": "^4.0.0",
    "memoize": "^10.0.0",
    "node-fetch": "^3.3.2",
    "qs": "6.15.2",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@hmcts/eslint-config": "^1.4.0",
    "chai": "^4.5",
    "eslint": "^9.10.0",
    "eslint-plugin-mocha": "^10.5.0",
    "mocha": "^10.7.3",
    "nyc": "^17.1.0",
    "sinon": "2",
    "sinon-stub-promise": "^4.0.0",
    "sonar-scanner": "^3.1.0"
  },
  "resolutions": {
    "lodash": "^4.18.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "yarn@4.10.3"
}
